APP_NAME=AidMatch API
APP_ENV=development
DEBUG=True
API_V1_STR=/api/v1

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aidmatch_db

JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

ADMIN_EMAIL=admin@aidmatch.com
ADMIN_PASSWORD=admin12345

FCM_ENABLED=False
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json